{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm run server:build",
    "start": "node --enable-source-maps artifacts/api-server/dist/index.mjs",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "expo:static:build": "pnpm --filter @workspace/mobile run build",
    "server:build": "pnpm --filter @workspace/api-server run build",
    "server:dev": "node --enable-source-maps artifacts/api-server/dist/index.mjs"
  },
  "packageManager": "pnpm@10.26.1",
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
