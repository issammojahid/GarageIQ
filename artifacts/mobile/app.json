{
  "expo": {
    "name": "GarageIQ",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.garageiq.app",
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-8545693631358718~1318648888"
      }
    },
    "android": {
      "package": "com.garageiq.app",
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-8545693631358718~1318648888"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "GarageIQ needs your location to find nearby workshops."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8545693631358718~1318648888",
          "iosAppId": "ca-app-pub-8545693631358718~1318648888"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
